{
  "mode": "auto",
  "generate_both_versions": true,
  "variants_per_mode": 2,
  "auto_select_best_variant": true,
  "use_langchain_orchestrator": true,
  "langchain_llm_enabled": false,
  "langchain_model": null,
  "sample_interval_seconds": 0.8,
  "min_segment_seconds": 1.5,
  "max_segment_seconds": 3.2,
  "tiktok_duration_seconds": [15, 30],
  "shopee_duration_seconds": [20, 45],
  "target_width": 1080,
  "target_height": 1920,
  "crf": 21,
  "preset": "medium",
  "enable_deshake": true,
  "enable_text_overlay": true,
  "enable_subtitles": true,
  "embed_subtitles_when_possible": false,
  "transcription_enabled": true,
  "whisper_model": "tiny",
  "transcription_language": "id",
  "asr_vad_enabled": true,
  "asr_auto_language_fallback": true,
  "speech_driven_editing_enabled": true,
  "beat_sync_enabled": true,
  "learning_enabled": true,
  "scene_understanding_enabled": true,
  "shot_boundary_detection_enabled": true,
  "shot_boundary_threshold": 0.32,
  "evaluator_enabled": true,
  "evaluator_min_score_to_keep": 0.52,
  "human_override_enabled": true,
  "override_filename": "overrides.json",
  "confidence_low_threshold": 0.55
}
